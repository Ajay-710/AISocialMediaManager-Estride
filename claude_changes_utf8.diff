+function buildWeeks(currentMonth) {
+  const monthStart = startOfMonth(currentMonth)
+  const start      = startOfWeek(monthStart)
+  const end        = endOfWeek(endOfMonth(monthStart))
+  const weeks      = []
+  let week         = []
+  let day          = start
+  while (day <= end) {
+    week.push(day)
+    if (week.length === 7) { weeks.push(week); week = [] }
+    day = addDays(day, 1)
+  }
+  return weeks
 }
 
